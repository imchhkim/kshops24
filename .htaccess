# URL 재작성 엔진 활성화
RewriteEngine On

# .env 파일에 대한 외부 웹 접근 차단
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# 상점 서브도메인 라우팅 (예: kshops24.com/momchicken -> shop_view.php?subdomain=momchicken)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)/?$ shop_view.php?subdomain=$1 [L,QSA]